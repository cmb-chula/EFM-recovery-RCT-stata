# ---- Data safety: never track real participant data --------------
# Block every data-file extension repo-wide, then allow ONLY the bundled
# synthetic example. A real CRF dropped anywhere will not be trackable.
*.xlsx
*.xls
*.xlsm
*.xlsb
*.dta
*.csv
*.tsv
*.sav
*.sas7bdat
*.parquet
*.pkl
*.zip
*.7z
*.rar

# Real or restricted data locations. These are intentionally broad.
data/raw/
data/real/
data/restricted/
raw/
real_data/
restricted/
private/
*Case Report Form*
*real*crf*
*Real*CRF*
*REAL*CRF*
*participant*
*patient*

# Public synthetic inputs are the only tracked data-file exceptions.
!data/synthetic/synthetic_crf.xlsx
!data/synthetic/reviewer_aggregate.csv
!data/synthetic/inter_rater.csv

# Analysis-ready data regenerated by 00_preprocess from the workbook.
data/clean/

# Timestamped run outputs (figures, tables, logs).
output/

# Stata batch-mode session logs written to the working directory.
*.log
master.log

# Internal QA notes are for private release preparation, not the public bundle.
QA_AUDIT*.md
QA_RELEASE_READINESS*.md

# OS / editor cruft
.DS_Store
*.swp

# Local Python environments used only for regenerating synthetic data.
.venv/
data/synthetic/.venv/
